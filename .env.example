GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
SUPABASE_URL="https://your-project.supabase.co"
# Server-only secret. Get it from Supabase → Project Settings → API → service_role key.
# Never commit this and never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# SQL Server (local ERP - ECO_2020)
MSSQL_SERVER="SRVAPP"
MSSQL_DATABASE="ECO_2020"
MSSQL_USER="crm_reader"
MSSQL_PASSWORD="CrmReader2024!"

# SMTP — used by scripts/digest-compras.ts and (later) seller event emails.
# Port 465 = implicit TLS (recommended). Port 587 = STARTTLS.
SMTP_HOST="mail.example.com"
SMTP_PORT="465"
SMTP_USER="notificaciones@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="notificaciones@example.com"
